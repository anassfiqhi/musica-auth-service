# Server Configuration
AUTH_SERVICE_PORT=8000
AUTH_SERVICE_HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/musica_auth

# Better-auth Configuration
BETTER_AUTH_SECRET=generate-with-openssl-rand-hex-16
BETTER_AUTH_URL=http://localhost:8000

# Frontend URLs (for CORS & redirects)
EXPO_PUBLIC_APP_URL=http://localhost:8081
PRODUCTION_APP_URL=https://app.example.com

# Email (Optional - for verification emails)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Redis (Optional - Phase 4 for caching & rate limiting)
# REDIS_URL=redis://localhost:6379
# RATE_LIMIT_ENABLED=false
